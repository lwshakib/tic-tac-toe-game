    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.2",
    "@workspace/eslint-config": "workspace:*",
    "eslint": "^9.39.2",
    "tsc-watch": "^7.2.0",
